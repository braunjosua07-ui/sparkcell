    "ink-spinner": "^5.0.0",
    "ink-table": "^3.0.0",
    "ink-text-input": "^6.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
